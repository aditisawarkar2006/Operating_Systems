9) Even or Odd
#!/bin/bash
echo "Enter a number:"
read num
if [ $((num % 2)) -eq 0 ]
then
    echo "Even"
else
    echo "Odd"
fi

10) Leap Year
#!/bin/bash
echo "Enter year:"
read year
if [ $((year % 400)) -eq 0 ]
then
    echo "Leap Year"
elif [ $((year % 100)) -eq 0 ]
then
    echo "Not Leap Year"
elif [ $((year % 4)) -eq 0 ]
then
    echo "Leap Year"
else
    echo "Not Leap Year"
fi

11) Grade Calculation
#!/bin/bash
echo "Enter marks:"
read marks
if [ $marks -ge 75 ]
then
    echo "Distinction"
elif [ $marks -ge 65 ]
then
    echo "First Division"
elif [ $marks -ge 55 ]
then
    echo "Second Division"
else
    echo "Third Division"
fi
