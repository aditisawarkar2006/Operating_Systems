3) Largest of 2 numbers
#!/bin/bash
echo "Enter two numbers:"
read a b
if [ $a -gt $b ]
then
    echo "$a is greater"
else
    echo "$b is greater"
fi

4) Largest of 3 numbers
#!/bin/bash
echo "Enter three numbers:"
read a b c
if [ $a -gt $b ] && [ $a -gt $c ]
then
    echo "$a is largest"
elif [ $b -gt $a ] && [ $b -gt $c ]
then
    echo "$b is largest"
else
    echo "$c is largest"
fi

